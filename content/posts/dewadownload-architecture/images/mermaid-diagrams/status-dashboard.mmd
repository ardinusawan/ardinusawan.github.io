    Node2Uptime --> Node3Status
    Node3Status --> Node3Response
    Node3Response --> Node3Rating
    Node3Rating --> Node3Uptime
    Node3Uptime --> SummaryTotal
    SummaryTotal --> SummaryHealthy
    SummaryHealthy --> SummaryDegraded
    SummaryDegraded --> SummaryDown
    SummaryDown --> ButtonRefresh
    ButtonRefresh --> ButtonLogs
    ButtonLogs --> ButtonAlerts
    
